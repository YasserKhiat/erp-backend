generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
  CLIENT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  BILLED
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum PaymentMethod {
  CASH
  CARD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum SupplierOrderStatus {
  DRAFT
  SUBMITTED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum LoyaltyTransactionType {
  EARN_ORDER
  BONUS_MILESTONE
  REDEEM_REWARD
  MANUAL_ADJUSTMENT
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  fullName     String
  phone        String?
  role         UserRole   @default(CLIENT)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  customerOrders Order[]  @relation("CustomerOrders")
  employeeOrders Order[]  @relation("EmployeeOrders")
  assignedTables DiningTable[] @relation("TableAssignedWaiter")
  carts        Cart[]
  payments     Payment[]
  addresses    ClientAddress[]
  preference   ClientPreference?
  favorites    FavoriteMenuItem[]
  reservations Reservation[]
  reviews      Review[]
  loyaltyAccount LoyaltyAccount?
  loyaltyTransactions LoyaltyTransaction[]
}

model DiningTable {
  id               String      @id @default(cuid())
  code             String      @unique
  seats            Int
  status           TableStatus @default(AVAILABLE)
  assignedWaiterId String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  assignedWaiter   User?       @relation("TableAssignedWaiter", fields: [assignedWaiterId], references: [id])
  orders           Order[]
  reservations     Reservation[]

  @@index([status])
  @@index([assignedWaiterId])
}

model Reservation {
  id         String            @id @default(cuid())
  userId     String?
  tableId    String
  guestCount Int
  startAt    DateTime
  endAt      DateTime
  status     ReservationStatus @default(PENDING)
  notes      String?
  cancelledAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  user       User?             @relation(fields: [userId], references: [id])
  table      DiningTable       @relation(fields: [tableId], references: [id])

  @@index([tableId, startAt, endAt])
  @@index([userId])
  @@index([status])
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  menuItems MenuItem[]
}

model MenuItem {
  id           String              @id @default(cuid())
  name         String
  description  String?
  price        Decimal             @db.Decimal(10, 2)
  isAvailable  Boolean             @default(true)
  categoryId   String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  category     Category            @relation(fields: [categoryId], references: [id])
  orderItems   OrderItem[]
  ingredients  MenuItemIngredient[]
  formulaItems FormulaBundleItem[]
  cartItems    CartItem[]
  favorites    FavoriteMenuItem[]
  reviews      Review[]

  @@index([categoryId])
}

model ClientAddress {
  id          String   @id @default(cuid())
  userId      String
  label       String
  addressLine String
  city        String
  postalCode  String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ClientPreference {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  dietaryRestrictions    String?
  allergens              String?
  preferredDeliveryNotes String?
  marketingOptIn         Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id])
}

model FavoriteMenuItem {
  id         String   @id @default(cuid())
  userId     String
  menuItemId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([userId, menuItemId])
  @@index([userId])
  @@index([menuItemId])
}

model FormulaBundle {
  id          String              @id @default(cuid())
  name        String              @unique
  description String?
  price       Decimal             @db.Decimal(10, 2)
  isAvailable Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  items       FormulaBundleItem[]

  @@index([isAvailable])
}

model FormulaBundleItem {
  id            String        @id @default(cuid())
  bundleId      String
  menuItemId    String
  quantity      Int           @default(1)
  formulaBundle FormulaBundle @relation(fields: [bundleId], references: [id])
  menuItem      MenuItem      @relation(fields: [menuItemId], references: [id])

  @@unique([bundleId, menuItemId])
  @@index([bundleId])
  @@index([menuItemId])
}

model Ingredient {
  id              String              @id @default(cuid())
  name            String              @unique
  unit            String
  minStockLevel   Decimal             @db.Decimal(10, 2)
  defaultSupplierId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  defaultSupplier Supplier?           @relation(fields: [defaultSupplierId], references: [id])
  inventory       Inventory?
  menuItems       MenuItemIngredient[]
  stockMovements  StockMovement[]
  supplierOrderItems SupplierOrderItem[]
}

model Supplier {
  id          String          @id @default(cuid())
  name        String
  email       String?
  phone       String?
  address     String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  ingredients Ingredient[]
  orders      SupplierOrder[]

  @@unique([name])
}

model SupplierOrder {
  id           String              @id @default(cuid())
  supplierId   String
  status       SupplierOrderStatus @default(DRAFT)
  notes        String?
  orderedAt    DateTime            @default(now())
  receivedAt   DateTime?
  totalAmount  Decimal             @db.Decimal(12, 2) @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  items        SupplierOrderItem[]

  @@index([supplierId])
  @@index([status])
}

model SupplierOrderItem {
  id               String        @id @default(cuid())
  supplierOrderId  String
  ingredientId     String
  quantity         Decimal       @db.Decimal(10, 2)
  unitCost         Decimal       @db.Decimal(10, 2)
  lineTotal        Decimal       @db.Decimal(12, 2)
  createdAt        DateTime      @default(now())
  supplierOrder    SupplierOrder @relation(fields: [supplierOrderId], references: [id])
  ingredient       Ingredient    @relation(fields: [ingredientId], references: [id])

  @@unique([supplierOrderId, ingredientId])
  @@index([supplierOrderId])
  @@index([ingredientId])
}

model Inventory {
  id            String     @id @default(cuid())
  ingredientId  String     @unique
  currentStock  Decimal    @db.Decimal(10, 2)
  updatedAt     DateTime   @updatedAt
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id])
}

model MenuItemIngredient {
  menuItemId      String
  ingredientId    String
  quantityNeeded  Decimal    @db.Decimal(10, 2)
  menuItem        MenuItem   @relation(fields: [menuItemId], references: [id])
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id])

  @@id([menuItemId, ingredientId])
}

model Order {
  id           String       @id @default(cuid())
  orderNumber  Int          @unique @default(autoincrement())
  customerId   String?
  employeeId   String?
  status       OrderStatus  @default(PENDING)
  orderType    OrderType
  tableNumber  Int?
  tableId      String?
  notes        String?
  billNumber   String?      @unique
  billedAt     DateTime?
  subtotal     Decimal      @db.Decimal(10, 2)
  tax          Decimal      @db.Decimal(10, 2)
  total        Decimal      @db.Decimal(10, 2)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  customer     User?        @relation("CustomerOrders", fields: [customerId], references: [id])
  employee     User?        @relation("EmployeeOrders", fields: [employeeId], references: [id])
  table        DiningTable? @relation(fields: [tableId], references: [id])
  items        OrderItem[]
  payments     Payment[]
  reviews      Review[]
  loyaltyTransactions LoyaltyTransaction[]

  @@index([customerId])
  @@index([employeeId])
  @@index([tableId])
  @@index([status])
}

model Cart {
  id         String     @id @default(cuid())
  userId     String
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  user       User       @relation(fields: [userId], references: [id])
  items      CartItem[]

  @@index([userId])
}

model CartItem {
  id          String    @id @default(cuid())
  cartId      String
  menuItemId  String
  quantity    Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cart        Cart      @relation(fields: [cartId], references: [id])
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id])

  @@unique([cartId, menuItemId])
  @@index([cartId])
}

model OrderItem {
  id          String    @id @default(cuid())
  orderId     String
  menuItemId  String
  quantity    Int
  unitPrice   Decimal   @db.Decimal(10, 2)
  totalPrice  Decimal   @db.Decimal(10, 2)
  order       Order     @relation(fields: [orderId], references: [id])
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id])
  reviews     Review[]

  @@index([orderId])
  @@index([menuItemId])
}

model Review {
  id          String   @id @default(cuid())
  userId      String
  orderId     String
  orderItemId String
  menuItemId  String
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  order       Order    @relation(fields: [orderId], references: [id])
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([userId, orderItemId])
  @@index([menuItemId, createdAt])
  @@index([orderId])
  @@index([userId])
}

model LoyaltyAccount {
  id              String   @id @default(cuid())
  userId          String   @unique
  points          Int      @default(0)
  lifetimePoints  Int      @default(0)
  completedOrders Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
  transactions    LoyaltyTransaction[]

  @@index([points])
}

model LoyaltyTransaction {
  id           String                 @id @default(cuid())
  accountId    String
  userId       String
  orderId      String?
  type         LoyaltyTransactionType
  pointsDelta  Int
  balanceAfter Int
  reason       String?
  referenceKey String?                @unique
  createdAt    DateTime               @default(now())
  account      LoyaltyAccount         @relation(fields: [accountId], references: [id])
  user         User                   @relation(fields: [userId], references: [id])
  order        Order?                 @relation(fields: [orderId], references: [id])

  @@index([accountId, createdAt])
  @@index([userId, createdAt])
  @@index([orderId])
}

model Payment {
  id            String        @id @default(cuid())
  orderId        String
  userId         String?
  amount         Decimal       @db.Decimal(10, 2)
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  transactionRef String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  order          Order         @relation(fields: [orderId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([createdAt])
}

model StockMovement {
  id            String            @id @default(cuid())
  ingredientId  String
  type          StockMovementType
  quantity      Decimal           @db.Decimal(10, 2)
  reason        String?
  createdAt     DateTime          @default(now())
  ingredient    Ingredient        @relation(fields: [ingredientId], references: [id])

  @@index([ingredientId])
  @@index([createdAt])
}

model DailyStat {
  id            String   @id @default(cuid())
  date          DateTime @unique
  totalRevenue  Decimal  @db.Decimal(12, 2) @default(0)
  totalOrders   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
