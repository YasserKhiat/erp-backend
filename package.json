{
  "name": "erp-backend",
  "version": "1.0.0",
  "description": "Restaurant ERP backend API",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "docker:up": "docker compose up --build",
    "docker:up:detached": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "docker:rebuild": "docker compose build --no-cache api",
    "docker:prisma:generate": "docker compose run --rm api npm run prisma:generate",
    "docker:prisma:deploy": "docker compose run --rm api npm run prisma:deploy",
    "docker:prisma:seed": "docker compose run --rm api npm run prisma:seed",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"{src,prisma}/**/*.{ts,js,json,md,prisma}\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "security:sca": "audit-ci --config ./audit-ci.json",
    "test": "npm run test:validation && npm run test:e2e",
    "test:validation": "npm run lint && npm run build",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:smoke": "node scripts/smoke-test.mjs"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "keywords": [
    "nest",
    "prisma",
    "restaurant",
    "erp"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.16.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.5",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cloudinary": "^2.9.0",
    "exceljs": "^4.4.0",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "audit-ci": "^7.1.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "prisma": "^6.16.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
